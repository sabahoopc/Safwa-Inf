rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // المؤثرون — القراءة مفتوحة، الكتابة مقيدة
    match /influencers/{id} {
      allow read: if true;
      allow write: if false; // الكتابة عبر Admin SDK فقط في الإنتاج
    }

    // الترشيحات — أي شخص يكتب، لكن لا يقرأ
    match /nominations/{id} {
      allow read:   if false;
      allow create: if request.resource.data.keys().hasAll(['name','field','links','reason','status','submittedAt'])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 100;
      allow update, delete: if false;
    }

    // البلاغات — نفس منطق الترشيحات
    match /removals/{id} {
      allow read:   if false;
      allow create: if request.resource.data.keys().hasAll(['target','reason','detail','status','submittedAt'])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.detail.size() >= 20;
      allow update, delete: if false;
    }
  }
}
